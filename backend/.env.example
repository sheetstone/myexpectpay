# ── Database ────────────────────────────────────────────────────────────────
# Connection string for the development database
DATABASE_URL=postgresql://postgres:password@localhost:5432/myexpertpay

# Separate database used by Jest integration tests (never the dev DB)
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/myexpertpay_test

# ── Firebase Admin SDK ───────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=myexpertpay
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@myexpertpay.iam.gserviceaccount.com
# Paste the private key with literal \n — the app replaces them at runtime
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex string used to encrypt stored bank account numbers
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Must match the exact origin of the frontend (no trailing slash)
CORS_ORIGIN=http://localhost:5173
